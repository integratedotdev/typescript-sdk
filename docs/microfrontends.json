{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "applications": {
    "integrate-docs": {
      "packageName": "integrate",
      "development": {
        "fallback": "https://integrate.dev"
      }
    },
    "integrate-dashboard": {
      "packageName": "integrate-dashboard",
      "assetPrefix": "dashboard-assets",
      "routing": [
        {
          "paths": [
            "/dashboard/:path*",
            "/dashboard-assets/:path*",
            "/vc-ap-13c0d8/:path*"
          ]
        }
      ]
    }
  }
}
